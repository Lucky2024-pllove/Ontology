  "rules": [
    {
      "id": "Rule-001",
      "name": "合同金额非空且大于零",
      "type": "validation",
      "description": "提交或保存时金额必须有效",
      "trigger": { "event": "合同保存或提交", "target": "Entity-001", "timing": "持久化前" },
      "condition": { "expression": "amount != null && amount > 0", "description": "金额非空且大于0" },
      "actions": {
        "onTrue": ["继续保存"],
        "onFalse": ["拒绝保存", "提示金额无效"]
      },
      "priority": 900,
      "scope": "全局",
      "dependsOn": [],
      "triggers": [],
      "metadata": {}
    },
    {
      "id": "Rule-002",
      "name": "付款条款比例之和为100%",
      "type": "validation",
      "description": "所有付款条款比例合计须为100%",
      "trigger": { "event": "合同保存或提交", "target": "Entity-001", "timing": "持久化前" },
      "condition": {
        "expression": "SUM(paymentTerms.ratio) == 100",
        "description": "分期比例合计100%"
      },
      "actions": {
        "onTrue": ["继续"],
        "onFalse": ["拒绝", "提示调整付款条款"]
      },
      "priority": 850,
      "scope": "含付款条款的合同",
      "dependsOn": [],
      "triggers": [],
      "metadata": {}
    },
    {
      "id": "Rule-003",
      "name": "大额合同必须审批",
      "type": "business",
      "description": "金额达到阈值须进入审批流",
      "trigger": { "event": "提交审批", "target": "Entity-001", "timing": "提交时" },
      "condition": { "expression": "amount >= threshold", "description": "金额>=阈值（如10万）" },
      "actions": {
        "onTrue": ["创建审批任务", "状态=待审批"],
        "onFalse": ["可走快速通道或仍需审批（策略可配）"]
      },
      "priority": 700,
      "scope": "提交审批",
      "dependsOn": ["Rule-001", "Rule-002"],
      "triggers": [],
      "metadata": { "threshold": 100000 }
    },
    {
      "id": "Rule-004",
      "name": "合同状态转换合法",
      "type": "state",
      "description": "仅允许预定义状态迁移",
      "trigger": { "event": "状态变更", "target": "Entity-001", "timing": "更新前" },
      "condition": {
        "expression": "(from,to) in ALLOWED_TRANSITIONS",
        "description": "迁移在白名单内"
      },
      "actions": {
        "onTrue": ["允许更新"],
        "onFalse": ["拒绝非法迁移"]
      },
      "priority": 800,
      "scope": "全局",
      "dependsOn": [],
      "triggers": [],
      "metadata": {
        "allowed": [
          ["草稿", "待审批"],
          ["草稿", "已作废"],
          ["待审批", "已生效"],
          ["待审批", "草稿"],
          ["已生效", "已完结"],
          ["已生效", "已作废"]
        ]
      }
    },
    {
      "id": "Rule-005",
      "name": "累计开票不超过合同金额",
      "type": "validation",
      "description": "开票累计校验",
      "trigger": { "event": "开具发票", "target": "Entity-004", "timing": "开票前" },
      "condition": {
        "expression": "SUM(invoices.amount) + current <= contract.amount",
        "description": "累计开票+本次<=合同金额"
      },
      "actions": {
        "onTrue": ["允许开票"],
        "onFalse": ["拒绝", "提示超额"]
      },
      "priority": 750,
      "scope": "开票",
      "dependsOn": [],
      "triggers": [],
      "metadata": {}
    },
    {
      "id": "Rule-006",
      "name": "作废前检查未结清发票",
      "type": "business",
      "description": "存在有效已开票时需先红冲或处理",
      "trigger": { "event": "作废合同", "target": "Entity-001", "timing": "作废前" },
      "condition": {
        "expression": "!hasBlockingInvoices(contractId)",
        "description": "无阻塞作废的发票状态"
      },
      "actions": {
        "onTrue": ["允许作废"],
        "onFalse": ["阻断并提示先处理发票"]
      },
      "priority": 720,
      "scope": "作废",
      "dependsOn": [],
      "triggers": [],
      "metadata": {}
    }
